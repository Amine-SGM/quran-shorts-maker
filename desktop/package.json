{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Quran Shorts Maker Desktop Build",
  "author": "Amine",
  "private": true,
  "main": "dist/src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run copy:static",
    "build:main": "tsc",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "esbuild src/renderer/index.tsx --bundle --outfile=dist/src/renderer/bundle.js --platform=browser --format=iife --jsx=transform",
    "copy:static": "cp src/renderer/index.html dist/src/renderer/index.html && cp src/renderer/styles.css dist/src/renderer/styles.css",
    "test": "jest",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.quranshortsmaker.desktop",
    "productName": "Quran Shorts Maker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "extraResources": [
      "bin/**/*"
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "skia-canvas": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/skia-canvas": "^0.9.2",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}